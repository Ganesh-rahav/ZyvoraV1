# ============================================================
# ZYVORA ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zyvora
NODE_ENV=development

# ------------------------------------------------------------
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# OPENAI
# Get this from: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# ------------------------------------------------------------
# STRIPE (Future - Sprint 7)
# Get these from: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ------------------------------------------------------------
# EMAIL PROVIDER (Resend)
# Get this from: https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@zyvora.ai

# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
# Used for encrypting sensitive data. Must be 32+ random characters.
ENCRYPTION_SECRET=your-32-character-minimum-random-secret-key

# ------------------------------------------------------------
# MONITORING (Future)
# ------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================
# SPRINT 4A — AI VISION INFRASTRUCTURE
# ============================================================

# ------------------------------------------------------------
# VISION PROVIDER
# Options: mock | openai | gemini | anthropic
# Default: mock (works without any API key)
# ------------------------------------------------------------
NEXT_PUBLIC_VISION_PROVIDER=mock

# ------------------------------------------------------------
# STORAGE PROVIDER
# Options: mock | supabase | s3 | r2 | azure
# Default: mock (stores blob: URLs in memory, no persistence)
# Wire supabase in the Auth sprint.
# ------------------------------------------------------------
NEXT_PUBLIC_STORAGE_PROVIDER=mock
NEXT_PUBLIC_STORAGE_BUCKET=physique-photos

# ------------------------------------------------------------
# UPLOAD CONFIGURATION
# All values have safe defaults in lib/ai/config.ts
# Override here if needed.
# ------------------------------------------------------------
# NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=10
# NEXT_PUBLIC_COMPRESSION_QUALITY=0.85
# NEXT_PUBLIC_MAX_DIMENSION_PX=2048

# ------------------------------------------------------------
# FEATURE FLAGS
# All default to false — enable explicitly per environment.
# ------------------------------------------------------------
# Enable real vision provider API calls (requires API key above)
NEXT_PUBLIC_FEATURE_REAL_VISION=false

# Enable Supabase Storage for photo persistence (requires Supabase credentials)
NEXT_PUBLIC_FEATURE_REAL_STORAGE=false

# Enable face blur canvas tool on upload screen
NEXT_PUBLIC_FEATURE_FACE_BLUR=false

# Enable structured audit event emission to backend
NEXT_PUBLIC_FEATURE_AUDIT_LOGGING=false
